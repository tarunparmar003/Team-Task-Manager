# Root .env used by docker-compose for local development.
# Copy to .env and adjust values.

# Postgres
POSTGRES_USER=tasks
POSTGRES_PASSWORD=tasks
POSTGRES_DB=tasks
POSTGRES_PORT=5432

# Server
SERVER_PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173

# Client (build-time)
VITE_API_URL=http://localhost:4000
